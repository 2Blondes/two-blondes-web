# Copia este archivo como ".env" para desarrollo local.
# EN RENDER: estas mismas variables se configuran en el panel "Environment", no en un archivo.

# Cadena de conexion de MongoDB Atlas
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster0.xxxxx.mongodb.net/two_blondes

# Email del que envia y recibe los avisos (Gmail)
EMAIL_USER=twoblondesstudio@gmail.com
# Contraseña de aplicacion de Gmail (NO la contraseña normal, ver README paso 3)
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Email al que llegan las solicitudes de acceso admin
OWNER_EMAIL=twoblondesstudio@gmail.com

# Contraseña maestra para que vosotros entreis siempre, sin pasar por el flujo de solicitud
MASTER_ADMIN_PASSWORD=cambia-esto-por-algo-seguro

# Clave secreta para firmar la sesion de admin (cualquier cadena larga y aleatoria)
JWT_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria

# URL publica de la web una vez desplegada (para los enlaces de los emails)
PUBLIC_URL=https://two-blondes.onrender.com

PORT=3000
